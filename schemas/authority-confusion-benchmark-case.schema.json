{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authority Confusion Benchmark Case v0.9.0",
  "type": "object",
  "required": [
    "id",
    "title",
    "category",
    "localOnly",
    "alreadyRedacted",
    "redactedHandoff",
    "temptingPhrase",
    "authorityEvidencePresent",
    "contextEvidencePresent",
    "naiveLikelyDecision",
    "expectedSafeDecision",
    "goldReason",
    "forbiddenCapabilities"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AC-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "localOnly": {
      "const": true
    },
    "alreadyRedacted": {
      "const": true
    },
    "redactedHandoff": {
      "type": "string"
    },
    "temptingPhrase": {
      "type": "string"
    },
    "authoritySignals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missingAuthorityFields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "authorityEvidencePresent": {
      "const": false
    },
    "contextEvidencePresent": {
      "const": true
    },
    "naiveLikelyDecision": {
      "enum": [
        "permit",
        "abstain",
        "degrade",
        "reject"
      ]
    },
    "expectedSafeDecision": {
      "enum": [
        "abstain",
        "degrade",
        "reject"
      ]
    },
    "goldReason": {
      "type": "string"
    },
    "forbiddenCapabilities": {
      "type": "object",
      "additionalProperties": {
        "const": false
      }
    }
  },
  "additionalProperties": false
}
