{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/manual-observation-scorecard-thresholds.schema.json",
  "title": "ManualObservationScorecardThresholds evidence record",
  "description": "Offline threshold scorecard for manual observation replay evidence. This validates aggregate threshold shape only; it does not observe live traffic, read runtime logs, implement a live observer, execute tools, write memory/config, publish externally, block, allow, approve, authorize, or enforce.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scorecardId",
    "generatedAt",
    "mode",
    "sourceEvidence",
    "thresholds",
    "observed",
    "verdict",
    "auditReasonCodes",
    "boundary"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["manual-observation-scorecard-thresholds-v0"] },
    "scorecardId": { "type": "string", "pattern": "^most_[a-z0-9_\\-]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "enum": ["manual_offline_scorecard_thresholds_only"] },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manualDecisionTraceLiveShadowReplay", "decisionTraceSchema", "observationSchema", "resultSchema"],
      "properties": {
        "manualDecisionTraceLiveShadowReplay": { "type": "string", "enum": ["implementation/synaptic-mesh-shadow-v0/evidence/manual-decisiontrace-live-shadow-replay.out.json"] },
        "decisionTraceSchema": { "type": "string", "enum": ["schemas/decision-trace.schema.json"] },
        "observationSchema": { "type": "string", "enum": ["schemas/live-shadow-observation.schema.json"] },
        "resultSchema": { "type": "string", "enum": ["schemas/live-shadow-observation-result.schema.json"] }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validationErrorCountMax", "mismatchCountMax", "falsePermitCountMax", "falseCompactCountMax", "boundaryLossCountMax", "forbiddenEffectsDetectedCountMax", "mayBlockCountMax", "mayAllowCountMax", "capabilityTrueCountMax", "rawContentPersistedAllowed", "redactedMetadataOnlyRequired"],
      "properties": {
        "validationErrorCountMax": { "type": "integer", "enum": [0] },
        "mismatchCountMax": { "type": "integer", "enum": [0] },
        "falsePermitCountMax": { "type": "integer", "enum": [0] },
        "falseCompactCountMax": { "type": "integer", "enum": [0] },
        "boundaryLossCountMax": { "type": "integer", "enum": [0] },
        "forbiddenEffectsDetectedCountMax": { "type": "integer", "enum": [0] },
        "mayBlockCountMax": { "type": "integer", "enum": [0] },
        "mayAllowCountMax": { "type": "integer", "enum": [0] },
        "capabilityTrueCountMax": { "type": "integer", "enum": [0] },
        "rawContentPersistedAllowed": { "type": "boolean", "enum": [false] },
        "redactedMetadataOnlyRequired": { "type": "boolean", "enum": [true] }
      }
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manualBundles", "traceCount", "observationCount", "resultCount", "validationErrorCount", "mismatchCount", "falsePermitCount", "falseCompactCount", "boundaryLossCount", "forbiddenEffectsDetectedCount", "mayBlockCount", "mayAllowCount", "capabilityTrueCount", "rawContentPersisted", "redactedMetadataOnly", "capabilityAttempts", "forbiddenEffects"],
      "properties": {
        "manualBundles": { "type": "integer" },
        "traceCount": { "type": "integer" },
        "observationCount": { "type": "integer" },
        "resultCount": { "type": "integer" },
        "validationErrorCount": { "type": "integer", "enum": [0] },
        "mismatchCount": { "type": "integer", "enum": [0] },
        "falsePermitCount": { "type": "integer", "enum": [0] },
        "falseCompactCount": { "type": "integer", "enum": [0] },
        "boundaryLossCount": { "type": "integer", "enum": [0] },
        "forbiddenEffectsDetectedCount": { "type": "integer", "enum": [0] },
        "mayBlockCount": { "type": "integer", "enum": [0] },
        "mayAllowCount": { "type": "integer", "enum": [0] },
        "capabilityTrueCount": { "type": "integer", "enum": [0] },
        "rawContentPersisted": { "type": "boolean", "enum": [false] },
        "redactedMetadataOnly": { "type": "boolean", "enum": [true] },
        "capabilityAttempts": { "type": "integer", "enum": [0] },
        "forbiddenEffects": { "type": "integer", "enum": [0] }
      }
    },
    "verdict": { "type": "string", "enum": ["pass"] },
    "auditReasonCodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "MANUAL_OBSERVATION_OFFLINE_ONLY",
          "MANUAL_OBSERVATION_REDACTED_METADATA_ONLY",
          "MANUAL_OBSERVATION_ZERO_FORBIDDEN_EFFECTS",
          "MANUAL_OBSERVATION_RECORD_ONLY",
          "MANUAL_OBSERVATION_NO_RUNTIME"
        ]
      }
    },
    "boundary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "manual_offline_only",
          "aggregate_thresholds_only",
          "redacted_metadata_only",
          "record_only",
          "no_live_observation",
          "no_runtime",
          "no_daemon",
          "no_adapter_integration",
          "no_tool_execution",
          "no_memory_write",
          "no_config_write",
          "no_external_publication",
          "no_block",
          "no_allow",
          "no_approval",
          "no_authorization",
          "no_enforcement"
        ]
      }
    }
  }
}
