{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/redaction-policy.schema.json",
  "title": "RedactionPolicy executable gate contract",
  "description": "Offline policy schema for executable redaction gates over already-curated local-shadow evidence. This policy describes reject-only sensitive-field classes and no-persistence invariants; it does not read live traffic, retain raw prompts, execute tools, write memory/config, publish externally, enter approval paths, block runtime actions, allow runtime actions, authorize, or enforce.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyId",
    "mode",
    "redactionGate",
    "defaultAction",
    "sensitiveFieldClasses",
    "requiredOutputFlags",
    "rawContentPersisted",
    "secretLikePersisted",
    "privatePathPersisted",
    "toolOutputPersisted",
    "memoryTextPersisted",
    "configTextPersisted",
    "approvalTextPersisted",
    "longRawPromptPersisted",
    "unknownSensitiveFieldPersisted",
    "boundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "redaction-policy-v0"
      ]
    },
    "policyId": {
      "type": "string",
      "pattern": "^rp_[a-z0-9_\\-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "manual_offline_executable_gate_only"
      ]
    },
    "redactionGate": {
      "type": "string",
      "enum": [
        "reject_sensitive_persistence"
      ]
    },
    "defaultAction": {
      "type": "string",
      "enum": [
        "reject_unknown_sensitive_field"
      ]
    },
    "sensitiveFieldClasses": {
      "type": "array",
      "minItems": 9,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "raw_content",
          "secret_like_value",
          "private_path",
          "tool_output",
          "memory_text",
          "config_text",
          "approval_text",
          "long_raw_prompt",
          "unknown_sensitive_field"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "raw_content"
          }
        },
        {
          "contains": {
            "const": "secret_like_value"
          }
        },
        {
          "contains": {
            "const": "private_path"
          }
        },
        {
          "contains": {
            "const": "tool_output"
          }
        },
        {
          "contains": {
            "const": "memory_text"
          }
        },
        {
          "contains": {
            "const": "config_text"
          }
        },
        {
          "contains": {
            "const": "approval_text"
          }
        },
        {
          "contains": {
            "const": "long_raw_prompt"
          }
        },
        {
          "contains": {
            "const": "unknown_sensitive_field"
          }
        }
      ]
    },
    "requiredOutputFlags": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "rawPersisted",
          "secretLikePersisted",
          "privatePathPersisted",
          "toolOutputPersisted",
          "memoryTextPersisted",
          "configTextPersisted",
          "approvalTextPersisted"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "rawPersisted"
          }
        },
        {
          "contains": {
            "const": "secretLikePersisted"
          }
        },
        {
          "contains": {
            "const": "privatePathPersisted"
          }
        },
        {
          "contains": {
            "const": "toolOutputPersisted"
          }
        },
        {
          "contains": {
            "const": "memoryTextPersisted"
          }
        },
        {
          "contains": {
            "const": "configTextPersisted"
          }
        },
        {
          "contains": {
            "const": "approvalTextPersisted"
          }
        }
      ]
    },
    "rawContentPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "secretLikePersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "privatePathPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "toolOutputPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "memoryTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "configTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "approvalTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "longRawPromptPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "unknownSensitiveFieldPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "boundary": {
      "type": "array",
      "minItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "manual_offline_only",
          "already_redacted_or_placeholder_fixtures_only",
          "reject_only_redaction_gate",
          "raw_content_not_persisted",
          "secret_like_values_not_persisted",
          "private_paths_not_persisted",
          "tool_outputs_not_persisted",
          "memory_text_not_persisted",
          "config_text_not_persisted",
          "approval_text_not_persisted",
          "long_raw_prompt_not_persisted",
          "unknown_sensitive_fields_rejected",
          "no_live_observation",
          "no_runtime",
          "no_daemon",
          "no_watcher",
          "no_adapter_integration",
          "no_tool_execution",
          "no_memory_write",
          "no_config_write",
          "no_external_publication",
          "no_approval_path",
          "no_blocking",
          "no_allowing",
          "no_authorization",
          "no_enforcement"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "manual_offline_only"
          }
        },
        {
          "contains": {
            "const": "already_redacted_or_placeholder_fixtures_only"
          }
        },
        {
          "contains": {
            "const": "reject_only_redaction_gate"
          }
        },
        {
          "contains": {
            "const": "raw_content_not_persisted"
          }
        },
        {
          "contains": {
            "const": "secret_like_values_not_persisted"
          }
        },
        {
          "contains": {
            "const": "private_paths_not_persisted"
          }
        },
        {
          "contains": {
            "const": "tool_outputs_not_persisted"
          }
        },
        {
          "contains": {
            "const": "memory_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "config_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "approval_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "long_raw_prompt_not_persisted"
          }
        },
        {
          "contains": {
            "const": "unknown_sensitive_fields_rejected"
          }
        },
        {
          "contains": {
            "const": "no_live_observation"
          }
        },
        {
          "contains": {
            "const": "no_runtime"
          }
        },
        {
          "contains": {
            "const": "no_daemon"
          }
        },
        {
          "contains": {
            "const": "no_watcher"
          }
        },
        {
          "contains": {
            "const": "no_adapter_integration"
          }
        },
        {
          "contains": {
            "const": "no_tool_execution"
          }
        },
        {
          "contains": {
            "const": "no_memory_write"
          }
        },
        {
          "contains": {
            "const": "no_config_write"
          }
        },
        {
          "contains": {
            "const": "no_external_publication"
          }
        },
        {
          "contains": {
            "const": "no_approval_path"
          }
        },
        {
          "contains": {
            "const": "no_blocking"
          }
        },
        {
          "contains": {
            "const": "no_allowing"
          }
        },
        {
          "contains": {
            "const": "no_authorization"
          }
        },
        {
          "contains": {
            "const": "no_enforcement"
          }
        }
      ]
    }
  }
}
