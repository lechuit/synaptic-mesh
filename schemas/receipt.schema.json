{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/receipt.schema.json",
  "title": "Receipt evidence record",
  "description": "Strict local shadow-only schema for structured receipt evidence derived from the compact receipt tuple. This validates receipt shape, boundary vocabulary, and stable audit fields only; it does not prove semantic correctness, freshness truth, source authenticity, policy correctness, or runtime authorization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receiptId",
    "version",
    "producedAt",
    "producedBy",
    "source",
    "policyChecksum",
    "grammarDigest",
    "policyWindow",
    "freshness",
    "scope",
    "promotionBoundary",
    "forbiddenEffects",
    "lineage",
    "riskTier",
    "action"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,96}$"
    },
    "version": {
      "type": "string",
      "enum": ["receipt-v0"]
    },
    "producedAt": {
      "type": "string",
      "format": "date-time"
    },
    "producedBy": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,96}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactId", "path", "digest"],
      "properties": {
        "artifactId": {
          "type": "string",
          "pattern": "^T-[A-Za-z0-9._:-]+$"
        },
        "path": {
          "type": "string",
          "pattern": "^(research-package|runs|implementation)/[A-Za-z0-9._:/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[A-Za-z0-9._:-]+$"
        }
      }
    },
    "policyChecksum": {
      "type": "string",
      "pattern": "^sha256:[A-Za-z0-9._:-]+$"
    },
    "grammarDigest": {
      "type": "string",
      "enum": ["sha256:compressed-temporal-receipt-v0"]
    },
    "policyWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validFrom", "validUntil"],
      "properties": {
        "validFrom": {
          "type": "string",
          "format": "date-time"
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "freshness": {
      "type": "string",
      "enum": ["current"]
    },
    "scope": {
      "type": "string",
      "enum": ["local_shadow"]
    },
    "promotionBoundary": {
      "type": "string",
      "enum": ["no_promotion_without_human"]
    },
    "forbiddenEffects": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["external", "runtime", "config", "delete", "publish", "memory"]
      }
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/#-]+$"
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completeness", "laterRestrictiveEvent"],
      "properties": {
        "completeness": {
          "type": "string",
          "enum": ["complete"]
        },
        "laterRestrictiveEvent": {
          "type": "string",
          "enum": ["none"]
        },
        "label": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$"
        }
      }
    },
    "riskTier": {
      "type": "string",
      "enum": ["low_local"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verb"],
      "properties": {
        "verb": {
          "type": "string",
          "enum": ["run_local_test", "write_local_report", "local_fixture_summary_check"]
        },
        "target": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:/#-]+$"
        }
      }
    }
  }
}
