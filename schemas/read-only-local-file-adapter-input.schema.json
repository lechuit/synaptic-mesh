{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/read-only-local-file-adapter-input.schema.json",
  "title": "Read-only local file adapter input v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "adapterMode",
    "sourceFilePath",
    "sourceArtifactDigest",
    "sourceAlreadyRedacted",
    "rawInputAllowed",
    "networkAllowed",
    "directoryInputAllowed",
    "globAllowed",
    "watcherAllowed",
    "daemonAllowed"
  ],
  "properties": {
    "schemaVersion": { "const": "read-only-local-file-adapter-input-v0" },
    "adapterMode": { "const": "manual_local_file_read_only" },
    "sourceFilePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[*?\\[\\]{}])(?!(?:[a-zA-Z][a-zA-Z0-9+.-]*:|//)).+[^/]$"
    },
    "sourceArtifactDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sourceAlreadyRedacted": { "const": true },
    "rawInputAllowed": { "const": false },
    "networkAllowed": { "const": false },
    "directoryInputAllowed": { "const": false },
    "globAllowed": { "const": false },
    "watcherAllowed": { "const": false },
    "daemonAllowed": { "const": false }
  }
}
