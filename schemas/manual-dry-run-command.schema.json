{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/manual-dry-run-command.schema.json",
  "title": "ManualDryRunCommand contract",
  "description": "Offline contract for a future manually invoked dry-run over already-redacted ManualObservationBundle artifacts. The command processes redacted artifacts; it does not capture reality, read live traffic, run as a watcher/daemon, access networks, execute tools, write memory/config, publish externally, enter approval paths, block, allow, authorize, enforce, or integrate with runtime hosts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commandId",
    "mode",
    "inputKind",
    "inputBundleId",
    "redactionReviewRequired",
    "humanInvocationRequired",
    "rawInputAllowed",
    "liveInputAllowed",
    "networkAllowed",
    "watcherAllowed",
    "daemonAllowed",
    "adapterIntegrationAllowed",
    "toolExecutionAllowed",
    "memoryWriteAllowed",
    "configWriteAllowed",
    "publicationAllowed",
    "blockingAllowed",
    "allowingAllowed",
    "approvalPathAllowed",
    "authorizationAllowed",
    "enforcementAllowed",
    "runtimeIntegrationAllowed",
    "expectedObserverAction",
    "outputKind",
    "rejectedInputKinds"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["manual-dry-run-command-v0"] },
    "commandId": { "type": "string", "pattern": "^dry_run_[a-z0-9_\\-]+$" },
    "mode": { "type": "string", "enum": ["manual_offline"] },
    "inputKind": { "type": "string", "enum": ["redacted_manual_observation_bundle"] },
    "inputBundleId": { "type": "string", "pattern": "^mob_[a-z0-9_\\-]+$" },
    "redactionReviewRequired": { "type": "boolean", "enum": [true] },
    "humanInvocationRequired": { "type": "boolean", "enum": [true] },
    "rawInputAllowed": { "type": "boolean", "enum": [false] },
    "liveInputAllowed": { "type": "boolean", "enum": [false] },
    "networkAllowed": { "type": "boolean", "enum": [false] },
    "watcherAllowed": { "type": "boolean", "enum": [false] },
    "daemonAllowed": { "type": "boolean", "enum": [false] },
    "adapterIntegrationAllowed": { "type": "boolean", "enum": [false] },
    "toolExecutionAllowed": { "type": "boolean", "enum": [false] },
    "memoryWriteAllowed": { "type": "boolean", "enum": [false] },
    "configWriteAllowed": { "type": "boolean", "enum": [false] },
    "publicationAllowed": { "type": "boolean", "enum": [false] },
    "blockingAllowed": { "type": "boolean", "enum": [false] },
    "allowingAllowed": { "type": "boolean", "enum": [false] },
    "approvalPathAllowed": { "type": "boolean", "enum": [false] },
    "authorizationAllowed": { "type": "boolean", "enum": [false] },
    "enforcementAllowed": { "type": "boolean", "enum": [false] },
    "runtimeIntegrationAllowed": { "type": "boolean", "enum": [false] },
    "expectedObserverAction": { "type": "string", "enum": ["record_only"] },
    "outputKind": { "type": "string", "enum": ["local_evidence_record_only"] },
    "rejectedInputKinds": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "raw_handoff_text",
          "unredacted_manual_observation_bundle",
          "live_session_stream",
          "live_log_stream",
          "runtime_event",
          "network_url",
          "tool_output",
          "memory_text",
          "config_text",
          "approval_text"
        ]
      },
      "allOf": [
        { "contains": { "type": "string", "enum": ["raw_handoff_text"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["unredacted_manual_observation_bundle"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["live_session_stream"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["live_log_stream"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["runtime_event"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["network_url"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["tool_output"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["memory_text"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["config_text"] }, "minContains": 1 },
        { "contains": { "type": "string", "enum": ["approval_text"] }, "minContains": 1 }
      ]
    }
  }
}
