{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionCounterfactualReceiverChecklist local advisory contract",
  "description": "Schema for local advisory decision-counterfactual memory retrieval checklist fixtures. It proves only fixture behavior and does not implement memory writes, MemoryAtom, runtime, live observer, adapter integration, tool authorization, publication, or enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "boundary",
    "requiredSlots",
    "forbiddenPromotions",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": {
      "const": "decision-counterfactual-checklist-v0.5"
    },
    "mode": {
      "const": "local_advisory_fixture_checklist_only"
    },
    "boundary": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 9,
      "items": {
        "type": "string"
      },
      "allOf": [
        {
          "contains": {
            "const": "local_markdown_json_node_only"
          }
        },
        {
          "contains": {
            "const": "no_memory_writes"
          }
        },
        {
          "contains": {
            "const": "no_memory_atom"
          }
        },
        {
          "contains": {
            "const": "no_runtime"
          }
        },
        {
          "contains": {
            "const": "no_live_observer"
          }
        },
        {
          "contains": {
            "const": "no_adapter_integration"
          }
        },
        {
          "contains": {
            "const": "no_tool_authorization"
          }
        },
        {
          "contains": {
            "const": "no_publication"
          }
        },
        {
          "contains": {
            "const": "no_enforcement"
          }
        }
      ]
    },
    "requiredSlots": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "enum": [
          "exact_current_action",
          "active_lane_source",
          "local_boundary",
          "blocked_effects",
          "fallback_or_fetch_path",
          "new_user_correction",
          "mutable_external_fact_status"
        ]
      }
    },
    "forbiddenPromotions": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 8,
      "items": {
        "enum": [
          "memory_write",
          "MemoryAtom",
          "runtime",
          "live_observer",
          "adapter_integration",
          "tool_authorization",
          "publication",
          "enforcement",
          "config_write",
          "paused_project_work"
        ]
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "sourceExperiment",
          "presentSlots",
          "signals",
          "expectedDecision",
          "expectedReasonCodes",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "sourceExperiment": {
            "enum": [
              "chat_fragment_ablation_v0",
              "live_user_correction_sample_v0"
            ]
          },
          "presentSlots": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "signals": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "expectedDecision": {
            "enum": [
              "allow_local_advisory",
              "fetch_or_abstain",
              "fetch_source_before_answer",
              "retire_stale_memory_no_action",
              "reject_sensitive_pressure"
            ]
          },
          "expectedReasonCodes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9_]+$"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
