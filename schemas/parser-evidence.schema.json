{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synaptic-mesh.local/schemas/parser-evidence.schema.json",
  "title": "ParserEvidence",
  "description": "Local-shadow evidence object produced from raw handoff artifacts before RouteDecision evaluation. Shape validation only; not parser robustness, authorization, runtime safety, or enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rawArtifactId",
    "rawInputShape",
    "receiptCandidatesFound",
    "validReceipts",
    "invalidReceipts",
    "freeTextAuthorityAttempts",
    "sensitiveSignals",
    "foldedIndex",
    "normalizationWarnings",
    "routeDecisionInputHash"
  ],
  "properties": {
    "rawArtifactId": { "type": "string", "minLength": 1 },
    "rawInputShape": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "receiptCandidatesFound": { "type": "integer", "minimum": 0 },
    "validReceipts": { "type": "integer", "minimum": 0 },
    "invalidReceipts": { "type": "integer", "minimum": 0 },
    "freeTextAuthorityAttempts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
      "uniqueItems": true
    },
    "sensitiveSignals": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
      "uniqueItems": true
    },
    "foldedIndex": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["present", "checksumMatches", "sensitivePromotionSeen"],
          "properties": {
            "present": { "type": "boolean" },
            "checksumMatches": { "type": "boolean" },
            "sensitivePromotionSeen": { "type": "boolean" }
          }
        }
      ]
    },
    "normalizationWarnings": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
      "uniqueItems": true
    },
    "routeDecisionInputHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
