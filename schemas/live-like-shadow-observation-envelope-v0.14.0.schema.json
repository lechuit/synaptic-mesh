{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/synaptic-mesh/schemas/live-like-shadow-observation-envelope-v0.14.0.schema.json",
  "title": "Synaptic Mesh live-like shadow/sandbox observation envelope v0.14.0-alpha",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "envelopeId",
    "mode",
    "sourceBoundary",
    "redaction",
    "observation",
    "forbiddenEffects"
  ],
  "properties": {
    "schemaVersion": { "const": "live-like-shadow-observation-envelope-v0.14.0-alpha" },
    "envelopeId": { "type": "string", "pattern": "^lls-[a-z0-9-]+$" },
    "mode": { "const": "live-like shadow/sandbox" },
    "sourceBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offlineFrozenAlreadyRedacted", "manualOrFrozenOnly", "liveTraffic", "network", "watcherDaemon", "frameworkAdapter", "sdkImport"],
      "properties": {
        "offlineFrozenAlreadyRedacted": { "const": true },
        "manualOrFrozenOnly": { "const": true },
        "liveTraffic": { "const": false },
        "network": { "const": false },
        "watcherDaemon": { "const": false },
        "frameworkAdapter": { "const": false },
        "sdkImport": { "const": false }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rawPrivateContent", "placeholdersOnly", "reviewedByHumanOrFixture"],
      "properties": {
        "status": { "const": "already-redacted" },
        "rawPrivateContent": { "const": false },
        "placeholdersOnly": { "const": true },
        "reviewedByHumanOrFixture": { "const": true }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAtFrozen", "channelLabel", "contentSummary", "labels"],
      "properties": {
        "observedAtFrozen": { "type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.000Z$" },
        "channelLabel": { "type": "string", "enum": ["manual-fixture", "frozen-transcript", "sandbox-synthetic"] },
        "contentSummary": { "type": "string", "minLength": 16 },
        "labels": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "forbiddenEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolExecution", "agentConsumed", "machineReadablePolicyDecision", "approvalBlockAllowAuthorizationEnforcement"],
      "properties": {
        "toolExecution": { "const": false },
        "agentConsumed": { "const": false },
        "machineReadablePolicyDecision": { "const": false },
        "approvalBlockAllowAuthorizationEnforcement": { "const": false }
      }
    }
  }
}
