    "sdkImported": { "const": false },
    "networkAllowed": { "const": false },
    "liveTrafficAllowed": { "const": false },
    "toolExecutionAllowed": { "const": false },
    "resourceFetchAllowed": { "const": false },
    "memoryWriteAllowed": { "const": false },
    "configWriteAllowed": { "const": false },
    "externalPublicationAllowed": { "const": false },
    "agentConsumedAllowed": { "const": false },
    "machineReadablePolicyAllowed": { "const": false },
    "approvalAllowed": { "const": false },
    "blockingAllowed": { "const": false },
    "allowingAllowed": { "const": false },
    "authorizationAllowed": { "const": false },
    "enforcementAllowed": { "const": false },
    "inputMode": { "const": "local_redacted_fixture_only" },
    "outputMode": { "const": "record_only_evidence" }
  }
}
