    "adapterShape",
    "frameworkKind",
    "realFrameworkIntegration",
    "sdkImported",
    "networkAllowed",
    "liveTrafficAllowed",
    "toolExecutionAllowed",
    "resourceFetchAllowed",
    "memoryWriteAllowed",
    "configWriteAllowed",
    "externalPublicationAllowed",
    "agentConsumedAllowed",
    "machineReadablePolicyAllowed",
    "approvalAllowed",
    "blockingAllowed",
    "allowingAllowed",
    "authorizationAllowed",
    "enforcementAllowed",
    "inputMode",
    "outputMode"
