{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/manual-dry-run-result.schema.json",
  "title": "ManualDryRunResult evidence record",
  "description": "Offline result contract for a future manual dry-run over already-redacted handoff bundles. The result is local record-only audit evidence; it cannot authorize, block, allow, execute tools, write memory, write config, publish externally, enter approval paths, enforce, or claim live-observer/runtime readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commandId",
    "resultId",
    "completed",
    "recordOnly",
    "generatedParserEvidence",
    "generatedClassifierDecision",
    "generatedDecisionTrace",
    "generatedLiveShadowResult",
    "generatedScorecardRow",
    "observerAction",
    "forbiddenEffectsDetected",
    "validationErrorCount",
    "mismatchCount",
    "falsePermitCount",
    "falseCompactCount",
    "boundaryLossCount",
    "rawContentPersisted",
    "privatePathsPersisted",
    "secretLikeValuesPersisted",
    "toolOutputsPersisted",
    "memoryTextPersisted",
    "configTextPersisted",
    "approvalTextPersisted",
    "mayBlock",
    "mayAllow",
    "mayExecuteTool",
    "mayWriteMemory",
    "mayWriteConfig",
    "mayPublishExternally",
    "mayModifyAgentInstructions",
    "mayEnterApprovalPath",
    "observerImplemented",
    "liveObserverImplemented",
    "watcherImplemented",
    "daemonImplemented",
    "networkAccessed",
    "adapterIntegrationImplemented",
    "runtimeIntegrationImplemented",
    "authorizationImplemented",
    "enforcementImplemented",
    "safetyClaimScope"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["manual-dry-run-result-v0"] },
    "commandId": { "type": "string", "pattern": "^dry_run_[a-z0-9_\\-]+$" },
    "resultId": { "type": "string", "pattern": "^dry_run_result_[a-z0-9_\\-]+$" },
    "completed": { "type": "boolean", "enum": [true] },
    "recordOnly": { "type": "boolean", "enum": [true] },
    "generatedParserEvidence": { "type": "boolean", "enum": [true] },
    "generatedClassifierDecision": { "type": "boolean", "enum": [true] },
    "generatedDecisionTrace": { "type": "boolean", "enum": [true] },
    "generatedLiveShadowResult": { "type": "boolean", "enum": [true] },
    "generatedScorecardRow": { "type": "boolean", "enum": [true] },
    "observerAction": { "type": "string", "enum": ["record_only"] },
    "forbiddenEffectsDetected": {
      "type": "array",
      "items": { "type": "string", "enum": [] },
      "maxItems": 0
    },
    "validationErrorCount": { "type": "integer", "enum": [0] },
    "mismatchCount": { "type": "integer", "enum": [0] },
    "falsePermitCount": { "type": "integer", "enum": [0] },
    "falseCompactCount": { "type": "integer", "enum": [0] },
    "boundaryLossCount": { "type": "integer", "enum": [0] },
    "rawContentPersisted": { "type": "boolean", "enum": [false] },
    "privatePathsPersisted": { "type": "boolean", "enum": [false] },
    "secretLikeValuesPersisted": { "type": "boolean", "enum": [false] },
    "toolOutputsPersisted": { "type": "boolean", "enum": [false] },
    "memoryTextPersisted": { "type": "boolean", "enum": [false] },
    "configTextPersisted": { "type": "boolean", "enum": [false] },
    "approvalTextPersisted": { "type": "boolean", "enum": [false] },
    "mayBlock": { "type": "boolean", "enum": [false] },
    "mayAllow": { "type": "boolean", "enum": [false] },
    "mayExecuteTool": { "type": "boolean", "enum": [false] },
    "mayWriteMemory": { "type": "boolean", "enum": [false] },
    "mayWriteConfig": { "type": "boolean", "enum": [false] },
    "mayPublishExternally": { "type": "boolean", "enum": [false] },
    "mayModifyAgentInstructions": { "type": "boolean", "enum": [false] },
    "mayEnterApprovalPath": { "type": "boolean", "enum": [false] },
    "observerImplemented": { "type": "boolean", "enum": [false] },
    "liveObserverImplemented": { "type": "boolean", "enum": [false] },
    "watcherImplemented": { "type": "boolean", "enum": [false] },
    "daemonImplemented": { "type": "boolean", "enum": [false] },
    "networkAccessed": { "type": "boolean", "enum": [false] },
    "adapterIntegrationImplemented": { "type": "boolean", "enum": [false] },
    "runtimeIntegrationImplemented": { "type": "boolean", "enum": [false] },
    "authorizationImplemented": { "type": "boolean", "enum": [false] },
    "enforcementImplemented": { "type": "boolean", "enum": [false] },
    "safetyClaimScope": { "type": "string", "enum": ["manual_dry_run_contract_only_not_cli_not_live_observer_not_runtime_not_authorization", "manual_dry_run_cli_minimal_local_file_redacted_bundle_record_only_not_live_observer_not_runtime_not_authorization"] }
  }
}
