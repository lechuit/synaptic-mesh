{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/synaptic-mesh/framework-adapter-dry-run-contract.schema.json",
  "title": "Framework Adapter Dry-Run Contract v0.8.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseLayer",
    "contractMode",
    "candidateFramework",
    "inputBoundary",
    "pipeline",
    "capabilities",
    "outputBoundary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "framework-adapter-dry-run-contract-v0"
    },
    "releaseLayer": {
      "const": "v0.8.3"
    },
    "contractMode": {
      "const": "dry_run_record_only"
    },
    "candidateFramework": {
      "const": "mcp_read_only_candidate"
    },
    "inputBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frameworkLikeLocalPacket",
        "alreadyRedacted",
        "explicitLocalFileOnly",
        "liveTrafficAllowed",
        "networkAllowed",
        "resourceFetchAllowed",
        "toolExecutionAllowed"
      ],
      "properties": {
        "frameworkLikeLocalPacket": {
          "const": true
        },
        "alreadyRedacted": {
          "const": true
        },
        "explicitLocalFileOnly": {
          "const": true
        },
        "liveTrafficAllowed": {
          "const": false
        },
        "networkAllowed": {
          "const": false
        },
        "resourceFetchAllowed": {
          "const": false
        },
        "toolExecutionAllowed": {
          "const": false
        }
      }
    },
    "pipeline": {
      "type": "array",
      "items": {
        "enum": [
          "accept_explicit_local_already_redacted_framework_like_packet",
          "validate_contract_boundary",
          "produce_record_only_human_review_evidence"
        ]
      },
      "minItems": 3,
      "maxItems": 3
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "const": false
      },
      "properties": {
        "realFrameworkAdapterImplemented": {
          "const": false
        },
        "frameworkIntegrationAuthorized": {
          "const": false
        },
        "sdkImported": {
          "const": false
        },
        "mcpServerClientImplemented": {
          "const": false
        },
        "networkUsed": {
          "const": false
        },
        "resourceFetched": {
          "const": false
        },
        "toolExecuted": {
          "const": false
        },
        "runtimeExecuted": {
          "const": false
        },
        "liveTrafficRead": {
          "const": false
        },
        "watcherDaemonImplemented": {
          "const": false
        },
        "memoryWritten": {
          "const": false
        },
        "configWritten": {
          "const": false
        },
        "publishedExternally": {
          "const": false
        },
        "agentConsumed": {
          "const": false
        },
        "machineReadablePolicyDecision": {
          "const": false
        },
        "approvalEmitted": {
          "const": false
        },
        "mayBlock": {
          "const": false
        },
        "mayAllow": {
          "const": false
        },
        "authorization": {
          "const": false
        },
        "enforcement": {
          "const": false
        }
      }
    },
    "outputBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recordOnly",
        "humanReviewOnly",
        "machineReadablePolicyDecision",
        "agentConsumed"
      ],
      "properties": {
        "recordOnly": {
          "const": true
        },
        "humanReviewOnly": {
          "const": true
        },
        "machineReadablePolicyDecision": {
          "const": false
        },
        "agentConsumed": {
          "const": false
        }
      }
    }
  }
}
