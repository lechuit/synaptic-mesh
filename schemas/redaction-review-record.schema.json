{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/redaction-review-record.schema.json",
  "title": "RedactionReviewRecord evidence record",
  "description": "Offline schema for the human redaction review barrier that must approve a manually curated handoff before local replay. This validates review-record shape and hard no-persistence invariants only; it does not read raw handoffs, observe live traffic, read runtime logs, implement a watcher/daemon/observer, execute tools, write memory/config, publish externally, enter approval paths, block, allow, authorize, or enforce.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewId",
    "bundleId",
    "captureMode",
    "reviewedAt",
    "humanReviewed",
    "rawContentPersisted",
    "privatePathsPersisted",
    "secretLikeValuesPersisted",
    "toolOutputsPersisted",
    "memoryTextPersisted",
    "configTextPersisted",
    "approvalTextPersisted",
    "redactedMetadataOnly",
    "allowedForLocalShadowReplay",
    "forbiddenForLiveObservation",
    "forbiddenForRuntimeUse",
    "auditReasonCodes",
    "boundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "redaction-review-record-v0"
      ]
    },
    "reviewId": {
      "type": "string",
      "pattern": "^rrr_[a-z0-9_\\-]+$"
    },
    "bundleId": {
      "type": "string",
      "pattern": "^mob_[a-z0-9_\\-]+$"
    },
    "captureMode": {
      "type": "string",
      "enum": [
        "manual_offline"
      ]
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "humanReviewed": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "rawContentPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "privatePathsPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "secretLikeValuesPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "toolOutputsPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "memoryTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "configTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "approvalTextPersisted": {
      "type": "boolean",
      "enum": [
        false
      ]
    },
    "redactedMetadataOnly": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "allowedForLocalShadowReplay": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "forbiddenForLiveObservation": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "forbiddenForRuntimeUse": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "auditReasonCodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "REDACTION_REVIEW_HUMAN_REQUIRED",
          "RAW_CONTENT_NOT_PERSISTED",
          "PRIVATE_PATHS_NOT_PERSISTED",
          "SECRET_LIKE_VALUES_NOT_PERSISTED",
          "TOOL_OUTPUTS_NOT_PERSISTED",
          "MEMORY_TEXT_NOT_PERSISTED",
          "CONFIG_TEXT_NOT_PERSISTED",
          "APPROVAL_TEXT_NOT_PERSISTED",
          "REDACTED_METADATA_ONLY",
          "LOCAL_SHADOW_REPLAY_ONLY",
          "FORBID_LIVE_OBSERVATION",
          "FORBID_RUNTIME_USE"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "REDACTION_REVIEW_HUMAN_REQUIRED"
          }
        },
        {
          "contains": {
            "const": "RAW_CONTENT_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "PRIVATE_PATHS_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "SECRET_LIKE_VALUES_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "TOOL_OUTPUTS_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "MEMORY_TEXT_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "CONFIG_TEXT_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "APPROVAL_TEXT_NOT_PERSISTED"
          }
        },
        {
          "contains": {
            "const": "REDACTED_METADATA_ONLY"
          }
        },
        {
          "contains": {
            "const": "LOCAL_SHADOW_REPLAY_ONLY"
          }
        },
        {
          "contains": {
            "const": "FORBID_LIVE_OBSERVATION"
          }
        },
        {
          "contains": {
            "const": "FORBID_RUNTIME_USE"
          }
        }
      ]
    },
    "boundary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "manual_offline_only",
          "human_review_required",
          "redacted_metadata_only",
          "raw_content_not_persisted",
          "private_paths_not_persisted",
          "secret_like_values_not_persisted",
          "tool_outputs_not_persisted",
          "memory_text_not_persisted",
          "config_text_not_persisted",
          "approval_text_not_persisted",
          "local_shadow_replay_only",
          "no_live_observation",
          "no_runtime",
          "no_daemon",
          "no_watcher",
          "no_adapter_integration",
          "no_tool_execution",
          "no_memory_write",
          "no_config_write",
          "no_external_publication",
          "no_approval_path",
          "no_blocking",
          "no_allowing",
          "no_authorization",
          "no_enforcement"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "manual_offline_only"
          }
        },
        {
          "contains": {
            "const": "human_review_required"
          }
        },
        {
          "contains": {
            "const": "redacted_metadata_only"
          }
        },
        {
          "contains": {
            "const": "raw_content_not_persisted"
          }
        },
        {
          "contains": {
            "const": "private_paths_not_persisted"
          }
        },
        {
          "contains": {
            "const": "secret_like_values_not_persisted"
          }
        },
        {
          "contains": {
            "const": "tool_outputs_not_persisted"
          }
        },
        {
          "contains": {
            "const": "memory_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "config_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "approval_text_not_persisted"
          }
        },
        {
          "contains": {
            "const": "local_shadow_replay_only"
          }
        },
        {
          "contains": {
            "const": "no_live_observation"
          }
        },
        {
          "contains": {
            "const": "no_runtime"
          }
        },
        {
          "contains": {
            "const": "no_daemon"
          }
        },
        {
          "contains": {
            "const": "no_watcher"
          }
        },
        {
          "contains": {
            "const": "no_adapter_integration"
          }
        },
        {
          "contains": {
            "const": "no_tool_execution"
          }
        },
        {
          "contains": {
            "const": "no_memory_write"
          }
        },
        {
          "contains": {
            "const": "no_config_write"
          }
        },
        {
          "contains": {
            "const": "no_external_publication"
          }
        },
        {
          "contains": {
            "const": "no_approval_path"
          }
        },
        {
          "contains": {
            "const": "no_blocking"
          }
        },
        {
          "contains": {
            "const": "no_allowing"
          }
        },
        {
          "contains": {
            "const": "no_authorization"
          }
        },
        {
          "contains": {
            "const": "no_enforcement"
          }
        }
      ]
    }
  }
}
