{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lechuit/synaptic-mesh/schemas/decision-trace.schema.json",
  "title": "DecisionTrace evidence record",
  "description": "Local shadow-only schema for offline decision traces that bind parser evidence, route decision input, gold decisions, and classifier decisions. This validates trace shape and audit linkage only; it is not live observation, runtime enforcement, tool authorization, memory write, config change, external publication, or production safety evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceId",
    "flowId",
    "parserEvidenceRef",
    "parserEvidenceRefHash",
    "routeDecisionInputHash",
    "goldDecisionHash",
    "classifierDecisionHash",
    "matchedGold",
    "selectedRoute",
    "reasonCodes",
    "decisiveSignals",
    "rejectedRoutes",
    "boundaryVerdict",
    "mode",
    "scope"
  ],
  "properties": {
    "traceId": { "type": "string", "pattern": "^trace_[a-z0-9_\\-]+$" },
    "flowId": { "type": "string", "minLength": 1 },
    "parserEvidenceRef": { "type": "string", "minLength": 1 },
    "parserEvidenceRefHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "routeDecisionInputHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "goldDecisionHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "classifierDecisionHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "matchedGold": { "type": "boolean" },
    "selectedRoute": {
      "type": "string",
      "enum": [
        "block",
        "ask_human",
        "fetch_source",
        "request_full_receipt",
        "request_policy_refresh",
        "request_grammar_refresh",
        "shadow_only",
        "abstain"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
    },
    "decisiveSignals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
    },
    "rejectedRoutes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "enum": [
          "block",
          "ask_human",
          "fetch_source",
          "request_full_receipt",
          "request_policy_refresh",
          "request_grammar_refresh",
          "shadow_only",
          "abstain"
        ]
      },
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        ]
      }
    },
    "boundaryVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["falsePermit", "falseCompact", "boundaryLoss"],
      "properties": {
        "falsePermit": { "type": "boolean" },
        "falseCompact": { "type": "boolean" },
        "boundaryLoss": { "type": "boolean" }
      }
    },
    "mode": { "type": "string", "enum": ["offline_fixture_trace"] },
    "scope": { "type": "string", "enum": ["local_shadow_only"] }
  }
}
