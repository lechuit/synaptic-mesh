{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "read-only-local-file-batch-manifest.schema.json",
  "title": "ReadOnlyLocalFileBatchManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "batchMode",
    "explicitInputListOnly",
    "directoryDiscovery",
    "globAllowed",
    "watcherAllowed",
    "daemonAllowed",
    "networkAllowed",
    "liveTrafficAllowed",
    "recordOnly",
    "maxInputCount",
    "inputs"
  ],
  "properties": {
    "schemaVersion": {
      "const": "read-only-local-file-batch-manifest-v0"
    },
    "batchMode": {
      "const": "manual_explicit_redacted_file_list"
    },
    "explicitInputListOnly": {
      "const": true
    },
    "directoryDiscovery": {
      "const": false
    },
    "globAllowed": {
      "const": false
    },
    "watcherAllowed": {
      "const": false
    },
    "daemonAllowed": {
      "const": false
    },
    "networkAllowed": {
      "const": false
    },
    "liveTrafficAllowed": {
      "const": false
    },
    "recordOnly": {
      "const": true
    },
    "maxInputCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceFilePath",
          "sourceArtifactDigest",
          "sourceAlreadyRedacted",
          "redactionReviewRecordId"
        ],
        "properties": {
          "sourceFilePath": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[*?\\[\\]{}])(?!(?:[a-zA-Z][a-zA-Z0-9+.-]*:|//))[A-Za-z0-9_./-]+\\.json$"
          },
          "sourceArtifactDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "sourceAlreadyRedacted": {
            "const": true
          },
          "redactionReviewRecordId": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
