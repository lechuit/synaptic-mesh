{
  "name": "aletheia-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Aletheia — memory as governance for LLM agents. Workspace root.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "smoke:core-e2e": "pnpm -F @aletheia/core run smoke:e2e",
    "demo:live-llm": "node examples/live-llm-e2e/live-demo.mjs",
    "demo:live-llm:adversarial": "node examples/live-llm-e2e/live-demo-adversarial.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  }
}
