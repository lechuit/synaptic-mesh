{
  "schemaVersion": "manual-decisiontrace-live-shadow-replay-v0",
  "description": "Offline replay from manual bundle parserEvidence evidence into DecisionTrace and LiveShadowObservation/Result records. Uses redacted metadata and offline classifier decisions only; no live traffic, observer, runtime, tools, memory/config writes, publication, approval, blocking, allowing, or enforcement.",
  "sourceParserEvidenceReplay": "implementation/synaptic-mesh-shadow-v0/evidence/manual-bundle-parser-evidence-replay.out.json",
  "replayMode": "manual_offline_decisiontrace_live_shadow_replay_only",
  "observerMode": "passive",
  "observerAction": "record_only",
  "effectBoundary": "no_effects",
  "writeBoundary": "local_shadow_only",
  "allowedInputs": ["decision_trace", "parser_evidence", "route_decision_input", "classifier_decision"],
  "forbiddenPaths": [
    "runtime",
    "tools",
    "memory_write",
    "config_write",
    "external_publication",
    "agent_instruction",
    "approval_path"
  ],
  "mustRemainFalse": [
    "mayBlock",
    "mayAllow",
    "mayExecuteTool",
    "mayWriteMemory",
    "mayWriteConfig",
    "mayPublishExternally",
    "mayModifyAgentInstructions",
    "mayEnterApprovalPath"
  ],
  "boundary": [
    "manual_offline_only",
    "redacted_snapshot_only",
    "decision_trace_shape_only",
    "live_shadow_record_shape_only",
    "record_only",
    "raw_content_not_persisted",
    "local_shadow_only",
    "no_live_observation",
    "no_runtime",
    "no_tools",
    "no_memory_write",
    "no_config_write",
    "no_publication",
    "no_approval",
    "no_blocking",
    "no_allowing",
    "no_enforcement"
  ]
}
