{
  "schemaVersion": "simulated-framework-shaped-adapter-reproducibility-fixture-v0",
  "releaseLayer": "v0.7.3",
  "dependsOn": "v0.7.2-simulated-framework-shaped-adapter",
  "mode": "manual_local_framework_shaped_adapter_reproducibility_drift_record_only",
  "runs": 2,
  "negativeControls": [
    {
      "controlId": "summary-positive-case-count-drift",
      "mutateSummary": { "positiveCases": 3 },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "framework-kind-order-drift",
      "reverseFrameworkKinds": true,
      "expectedReasonCodes": ["SIMULATED_ADAPTER_FRAMEWORK_KIND_DRIFT", "SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "classifier-compact-allowed-regression",
      "mutateFirstClassifierDecision": { "compactAllowed": true },
      "mutateSummary": { "classifierCompactAllowedTrue": 1 },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_CLASSIFIER_COMPACT_DRIFT", "SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "machine-policy-flag-regression",
      "mutateSummary": { "machineReadablePolicyDecision": true },
      "mutateFirstClassifierDecision": { "machineReadablePolicyDecision": true },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_MACHINE_POLICY_DRIFT", "SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "agent-consumption-flag-regression",
      "mutateSummary": { "agentConsumed": true },
      "mutateFirstAdvisoryReport": { "agentConsumed": true },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_AGENT_CONSUMPTION_DRIFT", "SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "authorization-enforcement-regression",
      "mutateSummary": { "authorization": true, "enforcement": true },
      "mutateFirstResult": { "authorization": true, "enforcement": true },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_CAPABILITY_DRIFT", "SIMULATED_ADAPTER_SUMMARY_DRIFT"]
    },
    {
      "controlId": "decision-trace-boundary-verdict-drift",
      "mutateFirstDecisionTraceBoundaryVerdict": { "falseCompact": true },
      "expectedReasonCodes": ["SIMULATED_ADAPTER_DECISION_TRACE_DRIFT", "SIMULATED_ADAPTER_CLASSIFIER_COMPACT_DRIFT"]
    },
    {
      "controlId": "boundary-token-loss",
      "removeBoundaryToken": "no_enforcement",
      "expectedReasonCodes": ["SIMULATED_ADAPTER_BOUNDARY_DRIFT"]
    }
  ]
}
