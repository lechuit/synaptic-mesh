{
  "artifact": "T-synaptic-mesh-authority-claim-route-fixtures-v0",
  "status": "fixture_metadata_only_no_classifier",
  "purpose": "Define degradation route vocabulary for authority-claim fixtures so ask_human/requires_human does not become a generic uncertainty bucket.",
  "boundary": [
    "local_shadow_only",
    "fixture_metadata_only",
    "not_classifier",
    "not_runtime_enforcement",
    "not_config",
    "not_authorization",
    "no_external_effects"
  ],
  "routes": [
    {
      "id": "block",
      "humanRequiredDefault": false,
      "description": "Deterministically reject a prohibited or unsafe local action without needing new human input."
    },
    {
      "id": "ask_human",
      "humanRequiredDefault": true,
      "description": "Escalate when the requested authority depends on human approval, sensitive external effects, config/runtime changes, or consent."
    },
    {
      "id": "fetch_source",
      "humanRequiredDefault": false,
      "description": "Retrieve or re-check the cited source artifact before deciding."
    },
    {
      "id": "request_full_receipt",
      "humanRequiredDefault": false,
      "description": "Ask sender/system for an uncompressed receipt when compact metadata omits authority-critical fields."
    },
    {
      "id": "request_policy_refresh",
      "humanRequiredDefault": false,
      "description": "Refresh policy/project-rule evidence when current policy context is missing, stale, or contradictory."
    },
    {
      "id": "request_grammar_refresh",
      "humanRequiredDefault": false,
      "description": "Refresh the handoff/receipt grammar when parsing semantics are missing, stale, or version-conflicted."
    },
    {
      "id": "shadow_only",
      "humanRequiredDefault": false,
      "description": "Continue only in local shadow/research space; do not promote, integrate, publish, or authorize tools."
    },
    {
      "id": "abstain",
      "humanRequiredDefault": false,
      "description": "Make no authority decision when evidence is insufficient and no safe fetch/refresh route is available."
    }
  ],
