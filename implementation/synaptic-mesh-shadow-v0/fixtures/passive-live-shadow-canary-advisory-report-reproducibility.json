{
  "schemaVersion": "passive-live-shadow-canary-advisory-report-reproducibility-v0",
  "releaseLayer": "v0.3.3",
  "dependsOn": "v0.3.2-advisory-report-failure-catalog",
  "mode": "manual_local_advisory_report_reproducibility_drift_record_only",
  "description": "Deterministic local drift controls for the human-readable advisory report evidence. This is not runtime, not policy, not authority, and not automatically consumed by agents.",
  "runs": 2,
  "negativeControls": [
    {
      "controlId": "reject_report_text_byte_drift",
      "mutateReportTextAppend": "\nDrift: extra advisory sentence not in committed report.\n",
      "expectedReasonCodes": ["ADVISORY_REPORT_TEXT_HASH_DRIFT", "ADVISORY_REPORT_BYTE_COUNT_DRIFT"]
    },
    {
      "controlId": "reject_report_byte_count_mismatch",
      "mutateSummary": { "reportBytes": 1 },
      "expectedReasonCodes": ["ADVISORY_REPORT_BYTE_COUNT_DRIFT", "ADVISORY_REPORT_SUMMARY_DRIFT"]
    },
    {
      "controlId": "reject_summary_authority_flag_drift",
      "mutateSummary": { "nonAuthoritative": false },
      "expectedReasonCodes": ["ADVISORY_REPORT_SUMMARY_DRIFT", "ADVISORY_REPORT_AUTHORITY_BOUNDARY_DRIFT"]
    },
    {
      "controlId": "reject_source_evidence_order_drift",
      "reverseSourceEvidence": true,
      "expectedReasonCodes": ["ADVISORY_REPORT_SOURCE_EVIDENCE_DRIFT"]
    },
    {
      "controlId": "reject_machine_policy_flag_drift",
      "mutateSummary": { "machineReadablePolicyDecision": true },
      "expectedReasonCodes": ["ADVISORY_REPORT_SUMMARY_DRIFT", "ADVISORY_REPORT_AUTHORITY_BOUNDARY_DRIFT"]
    },
    {
      "controlId": "reject_committed_report_path_drift",
      "mutateSummary": { "reportPath": "implementation/synaptic-mesh-shadow-v0/evidence/other-report.md" },
      "expectedReasonCodes": ["ADVISORY_REPORT_SUMMARY_DRIFT", "ADVISORY_REPORT_REPORT_PATH_DRIFT"]
    }
  ]
}
