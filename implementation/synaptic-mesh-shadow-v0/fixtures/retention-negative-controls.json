{
  "schemaVersion": "retention-negative-controls-v0",
  "policyRef": "retp_v0_1_17_retention_gate",
  "mode": "manual_offline_retention_gate_only",
  "description": "Synthetic retention gate pass cases and negative controls. No deletion, retention scheduler, live observation, runtime integration, or raw/private content is implemented or required.",
  "passCases": [
    {
      "caseId": "pass_raw_live_input_zero_day",
      "artifactClass": "raw_live_input",
      "retentionDays": 0,
      "rawContentPersisted": false
    },
    {
      "caseId": "pass_redacted_observation_seven_days",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "rawContentPersisted": false
    },
    {
      "caseId": "pass_redacted_result_seven_days",
      "artifactClass": "redacted_result_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "rawContentPersisted": false
    },
    {
      "caseId": "pass_aggregate_scorecard_ninety_days",
      "artifactClass": "aggregate_scorecard",
      "retentionDays": 90,
      "aggregateOnly": true,
      "rawContentPersisted": false
    },
    {
      "caseId": "pass_public_release_evidence_synthetic",
      "artifactClass": "public_release_evidence",
      "syntheticOrNonSensitive": true,
      "rawContentPersisted": false
    }
  ],
  "negativeControls": [
    {
      "caseId": "reject_raw_live_input_retained",
      "artifactClass": "raw_live_input",
      "retentionDays": 1,
      "expectedReasonCode": "RETENTION_RAW_LIVE_INPUT_MUST_BE_ZERO_DAY"
    },
    {
      "caseId": "reject_redacted_observation_over_ceiling",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 8,
      "redactionStatus": "redacted",
      "expectedReasonCode": "RETENTION_CEILING_EXCEEDED"
    },
    {
      "caseId": "reject_redacted_result_over_ceiling",
      "artifactClass": "redacted_result_record",
      "retentionDays": 8,
      "redactionStatus": "redacted",
      "expectedReasonCode": "RETENTION_CEILING_EXCEEDED"
    },
    {
      "caseId": "reject_scorecard_over_ceiling",
      "artifactClass": "aggregate_scorecard",
      "retentionDays": 91,
      "aggregateOnly": true,
      "expectedReasonCode": "RETENTION_CEILING_EXCEEDED"
    },
    {
      "caseId": "reject_unknown_retention_class",
      "artifactClass": "private_memory_snapshot",
      "retentionDays": 7,
      "expectedReasonCode": "RETENTION_UNKNOWN_CLASS_REJECTED"
    },
    {
      "caseId": "reject_raw_content_persisted",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "rawContentPersisted": true,
      "expectedReasonCode": "RETENTION_RAW_CONTENT_PERSISTED"
    },
    {
      "caseId": "reject_missing_redaction_status",
      "artifactClass": "redacted_result_record",
      "retentionDays": 7,
      "expectedReasonCode": "RETENTION_REDACTION_STATUS_REQUIRED"
    },
    {
      "caseId": "reject_scorecard_not_aggregate_only",
      "artifactClass": "aggregate_scorecard",
      "retentionDays": 30,
      "aggregateOnly": false,
      "expectedReasonCode": "RETENTION_AGGREGATE_ONLY_REQUIRED"
    },
    {
      "caseId": "reject_public_evidence_not_synthetic",
      "artifactClass": "public_release_evidence",
      "syntheticOrNonSensitive": false,
      "expectedReasonCode": "RETENTION_PUBLIC_EVIDENCE_MUST_BE_SYNTHETIC_OR_NON_SENSITIVE"
    },
    {
      "caseId": "reject_retention_scheduler_implemented",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "retentionSchedulerImplemented": true,
      "expectedReasonCode": "RETENTION_SCHEDULER_FORBIDDEN"
    },
    {
      "caseId": "reject_deletion_implemented",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "deletionImplemented": true,
      "expectedReasonCode": "RETENTION_DELETION_IMPLEMENTATION_FORBIDDEN"
    },
    {
      "caseId": "reject_runtime_integration_implemented",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "runtimeIntegrationImplemented": true,
      "expectedReasonCode": "RETENTION_RUNTIME_INTEGRATION_FORBIDDEN"
    },
    {
      "caseId": "reject_live_observer_implemented",
      "artifactClass": "redacted_observation_record",
      "retentionDays": 7,
      "redactionStatus": "redacted",
      "liveObserverImplemented": true,
      "expectedReasonCode": "RETENTION_LIVE_OBSERVER_FORBIDDEN"
    }
  ],
  "boundary": [
    "manual_offline_only",
    "already_redacted_or_placeholder_fixtures_only",
    "retention_metadata_gate_only",
    "reject_only_retention_gate",
    "no_retention_scheduler",
    "no_deletion_implementation",
    "no_live_observation",
    "no_runtime",
    "no_daemon",
    "no_watcher",
    "no_adapter_integration",
    "no_tool_execution",
    "no_memory_write",
    "no_config_write",
    "no_external_publication",
    "no_approval_path",
    "no_blocking",
    "no_allowing",
    "no_authorization",
    "no_enforcement"
  ]
}
