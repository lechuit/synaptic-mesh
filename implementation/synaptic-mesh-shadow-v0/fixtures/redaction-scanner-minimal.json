{
  "schemaVersion": "redaction-scanner-minimal-fixtures-v0",
  "policyRef": "rp_v0_1_17_redaction_gate",
  "mode": "manual_offline_redaction_scan_only",
  "description": "Already-redacted or synthetic placeholder fixtures for the minimal executable redaction scanner gate. No real raw prompts, secrets, private paths, tool output, memory text, config text, or approval text are included.",
  "passCases": [
    {
      "caseId": "redacted_metadata_only_001",
      "persistedFields": ["caseId", "bundleRef", "routeDecisionInputHash", "redactionReviewId"],
      "bundleRef": "mob_real_redacted_001",
      "routeDecisionInputHash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "redactionReviewId": "rrr_real_redacted_001",
      "redactedMetadataOnly": true
    },
    {
      "caseId": "placeholder_summary_only_002",
      "persistedFields": ["caseId", "summary", "redactionLabels"],
      "summary": "Synthetic placeholder summary with no raw user content.",
      "redactionLabels": ["raw_removed", "secrets_removed", "paths_removed"],
      "redactedMetadataOnly": true
    }
  ],
  "blockCases": [
    {
      "caseId": "block_raw_content_persisted",
      "expectedReasonClass": "raw_content",
      "persistedFields": ["rawContent"],
      "rawContent": "RAW_CONTENT_PLACEHOLDER"
    },
    {
      "caseId": "block_secret_like_value",
      "expectedReasonClass": "secret_like_value",
      "persistedFields": ["secretValue"],
      "secretValue": "sk-SYNTHETICSECRET000000000000"
    },
    {
      "caseId": "block_private_path",
      "expectedReasonClass": "private_path",
      "persistedFields": ["privatePath"],
      "privatePath": "/Users/example/private/project/file.txt"
    },
    {
      "caseId": "block_tool_output",
      "expectedReasonClass": "tool_output",
      "persistedFields": ["toolOutput"],
      "toolOutput": "TOOL_OUTPUT_PLACEHOLDER"
    },
    {
      "caseId": "block_memory_text",
      "expectedReasonClass": "memory_text",
      "persistedFields": ["memoryText"],
      "memoryText": "MEMORY_TEXT_PLACEHOLDER"
    },
    {
      "caseId": "block_config_text",
      "expectedReasonClass": "config_text",
      "persistedFields": ["configText"],
      "configText": "CONFIG_TEXT_PLACEHOLDER"
    },
    {
      "caseId": "block_approval_text",
      "expectedReasonClass": "approval_text",
      "persistedFields": ["approvalText"],
      "approvalText": "APPROVAL_TEXT_PLACEHOLDER"
    },
    {
      "caseId": "block_long_raw_prompt",
      "expectedReasonClass": "long_raw_prompt",
      "persistedFields": ["longRawPrompt"],
      "rawPrompt": "LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER LONG_RAW_PROMPT_PLACEHOLDER"
    },
    {
      "caseId": "block_unknown_sensitive_field",
      "expectedReasonClass": "unknown_sensitive_field",
      "persistedFields": ["unknownSensitivePayload"],
      "unknownSensitivePayload": "UNKNOWN_SENSITIVE_PLACEHOLDER"
    }
  ],
  "boundary": [
    "manual_offline_only",
    "already_redacted_or_placeholder_fixtures_only",
    "reject_only_redaction_gate",
    "no_live_observation",
    "no_runtime",
    "no_daemon",
    "no_watcher",
    "no_adapter_integration",
    "no_tool_execution",
    "no_memory_write",
    "no_config_write",
    "no_external_publication",
    "no_approval_path",
    "no_blocking",
    "no_allowing",
    "no_authorization",
    "no_enforcement"
  ]
}
