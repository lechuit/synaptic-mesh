{
  "schemaVersion": "live-shadow-synthetic-replay-v0",
  "description": "Offline replay plan only. It maps existing DecisionTrace evidence into passive LiveShadowObservation and record_only LiveShadowObservationResult records without reading live traffic or implementing an observer.",
  "sourceEvidence": "implementation/synaptic-mesh-shadow-v0/evidence/decision-trace-schema.out.json",
  "observationSchema": "schemas/live-shadow-observation.schema.json",
  "resultSchema": "schemas/live-shadow-observation-result.schema.json",
  "replayMode": "synthetic_offline_only",
  "observerMode": "passive",
  "observerAction": "record_only",
  "effectBoundary": "no_effects",
  "writeBoundary": "local_shadow_only",
  "forbiddenPaths": ["runtime", "tools", "memory_write", "config_write", "external_publication", "agent_instruction", "approval_path"],
  "mustRemainFalse": ["mayBlock", "mayAllow", "mayExecuteTool", "mayWriteMemory", "mayWriteConfig", "mayPublishExternally", "mayModifyAgentInstructions", "mayEnterApprovalPath"],
  "boundary": [
    "offline_replay_only",
    "no_live_observation",
    "no_runtime",
    "no_daemon",
    "no_adapter_integration",
    "no_tool_execution",
    "no_memory_write",
    "no_config_write",
    "no_external_publication",
    "no_block",
    "no_allow",
    "no_approval",
    "no_enforcement"
  ]
}
