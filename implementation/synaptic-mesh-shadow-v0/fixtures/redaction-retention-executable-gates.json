{
  "schemaVersion": "redaction-retention-executable-gates-v0",
  "mode": "manual_offline_redaction_retention_gate_only",
  "description": "Synthetic executable redaction/retention composition gate over committed fixtures only. No live observation, retention scheduler, deletion implementation, runtime integration, memory write, tool execution, approval path, blocking/allowing, authorization, publication automation, or enforcement is implemented.",
  "passCases": [
    {
      "caseId": "pass_redacted_observation_within_ceiling",
      "redactionCandidate": {
        "caseId": "pass_redacted_observation_within_ceiling_redaction",
        "persistedFields": ["redactedSummary", "metadataOnly"]
      },
      "retentionCandidate": {
        "caseId": "pass_redacted_observation_within_ceiling_retention",
        "artifactClass": "redacted_observation_record",
        "retentionDays": 7,
        "redactionStatus": "redacted",
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "pass_aggregate_scorecard_metadata_only",
      "redactionCandidate": {
        "caseId": "pass_aggregate_scorecard_metadata_only_redaction",
        "persistedFields": ["aggregateCounts", "reasonCodeSummary"]
      },
      "retentionCandidate": {
        "caseId": "pass_aggregate_scorecard_metadata_only_retention",
        "artifactClass": "aggregate_scorecard",
        "retentionDays": 90,
        "aggregateOnly": true,
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "pass_public_release_evidence_synthetic_only",
      "redactionCandidate": {
        "caseId": "pass_public_release_evidence_synthetic_only_redaction",
        "persistedFields": ["syntheticFixtureSummary", "nonSensitiveEvidence"]
      },
      "retentionCandidate": {
        "caseId": "pass_public_release_evidence_synthetic_only_retention",
        "artifactClass": "public_release_evidence",
        "syntheticOrNonSensitive": true,
        "rawContentPersisted": false
      }
    }
  ],
  "rejectCases": [
    {
      "caseId": "reject_redaction_secret_before_retention",
      "expectedReasonCodes": ["REDACTION_GATE_REJECTED", "REDACTION_SECRET_LIKE_VALUE_PERSISTED"],
      "redactionCandidate": {
        "caseId": "reject_redaction_secret_before_retention_redaction",
        "apiKey": "sk-testfixture000000000000000000",
        "persistedFields": ["apiKey"]
      },
      "retentionCandidate": {
        "caseId": "reject_redaction_secret_before_retention_retention",
        "artifactClass": "public_release_evidence",
        "syntheticOrNonSensitive": true,
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "reject_redaction_private_path_before_retention",
      "expectedReasonCodes": ["REDACTION_GATE_REJECTED", "REDACTION_PRIVATE_PATH_PERSISTED"],
      "redactionCandidate": {
        "caseId": "reject_redaction_private_path_before_retention_redaction",
        "localPath": "/Users/example/private/project/secrets.txt",
        "persistedFields": ["privatePath"]
      },
      "retentionCandidate": {
        "caseId": "reject_redaction_private_path_before_retention_retention",
        "artifactClass": "redacted_result_record",
        "retentionDays": 7,
        "redactionStatus": "redacted",
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "reject_retention_over_ceiling_after_redaction_pass",
      "expectedReasonCodes": ["RETENTION_GATE_REJECTED", "RETENTION_CEILING_EXCEEDED"],
      "redactionCandidate": {
        "caseId": "reject_retention_over_ceiling_after_redaction_pass_redaction",
        "persistedFields": ["redactedSummary", "metadataOnly"]
      },
      "retentionCandidate": {
        "caseId": "reject_retention_over_ceiling_after_redaction_pass_retention",
        "artifactClass": "redacted_result_record",
        "retentionDays": 8,
        "redactionStatus": "redacted",
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "reject_missing_redaction_status_after_redaction_pass",
      "expectedReasonCodes": ["RETENTION_GATE_REJECTED", "RETENTION_REDACTION_STATUS_REQUIRED"],
      "redactionCandidate": {
        "caseId": "reject_missing_redaction_status_after_redaction_pass_redaction",
        "persistedFields": ["summaryOnly"]
      },
      "retentionCandidate": {
        "caseId": "reject_missing_redaction_status_after_redaction_pass_retention",
        "artifactClass": "redacted_observation_record",
        "retentionDays": 7,
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "reject_unknown_retention_class_after_redaction_pass",
      "expectedReasonCodes": ["RETENTION_GATE_REJECTED", "RETENTION_UNKNOWN_CLASS_REJECTED"],
      "redactionCandidate": {
        "caseId": "reject_unknown_retention_class_after_redaction_pass_redaction",
        "persistedFields": ["metadataOnly"]
      },
      "retentionCandidate": {
        "caseId": "reject_unknown_retention_class_after_redaction_pass_retention",
        "artifactClass": "private_memory_snapshot",
        "retentionDays": 7,
        "rawContentPersisted": false
      }
    },
    {
      "caseId": "reject_scheduler_or_deletion_pressure",
      "expectedReasonCodes": ["RETENTION_GATE_REJECTED", "RETENTION_DELETION_IMPLEMENTATION_FORBIDDEN", "RETENTION_SCHEDULER_FORBIDDEN"],
      "redactionCandidate": {
        "caseId": "reject_scheduler_or_deletion_pressure_redaction",
        "persistedFields": ["redactedSummary"]
      },
      "retentionCandidate": {
        "caseId": "reject_scheduler_or_deletion_pressure_retention",
        "artifactClass": "redacted_observation_record",
        "retentionDays": 7,
        "redactionStatus": "redacted",
        "rawContentPersisted": false,
        "retentionSchedulerImplemented": true,
        "deletionImplemented": true
      }
    },
    {
      "caseId": "reject_runtime_or_live_pressure",
      "expectedReasonCodes": ["RETENTION_GATE_REJECTED", "RETENTION_LIVE_OBSERVER_FORBIDDEN", "RETENTION_RUNTIME_INTEGRATION_FORBIDDEN"],
      "redactionCandidate": {
        "caseId": "reject_runtime_or_live_pressure_redaction",
        "persistedFields": ["redactedSummary"]
      },
      "retentionCandidate": {
        "caseId": "reject_runtime_or_live_pressure_retention",
        "artifactClass": "redacted_result_record",
        "retentionDays": 7,
        "redactionStatus": "redacted",
        "rawContentPersisted": false,
        "runtimeIntegrationImplemented": true,
        "liveObserverImplemented": true
      }
    }
  ],
  "boundary": [
    "manual_offline_only",
    "committed_fixtures_only",
    "redaction_first_retention_second",
    "local_evidence_output_only",
    "record_only",
    "no_live_observation",
    "no_runtime",
    "no_daemon",
    "no_watcher",
    "no_adapter_integration",
    "no_tool_execution",
    "no_memory_write",
    "no_config_write",
    "no_external_publication",
    "no_publication_automation",
    "no_approval_path",
    "no_blocking",
    "no_allowing",
    "no_authorization",
    "no_enforcement"
  ]
}
